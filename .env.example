# ─── AI Provider Configuration ───────────────────────────────────────
# Choose provider: "claude" | "openai"
AI_PROVIDER=claude

# Anthropic Claude
CLAUDE_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-5

# OpenAI / GPT-4o
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Server ───────────────────────────────────────────────────────────
PORT=3001

# ─── Auth ────────────────────────────────────────────────────────────
# Secret for signing JWT tokens — change this in production!
JWT_SECRET=change-me-in-production

# PostgreSQL connection string
# Local:   postgresql://user:password@localhost:5432/tennis_coach
# Render:  paste the "Internal Database URL" from Render dashboard
# Supabase: paste the "URI" from Project Settings → Database
DATABASE_URL=postgresql://user:password@localhost:5432/tennis_coach
