# ─── AI Provider Configuration ───────────────────────────────────────
# Choose provider: "claude" | "openai"
AI_PROVIDER=claude

# Anthropic Claude
CLAUDE_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-5

# OpenAI / GPT-4o
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── Server ───────────────────────────────────────────────────────────
PORT=3001
